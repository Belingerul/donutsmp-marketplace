// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Offer {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // what the seller is offering
  category     String
  game         String?
  itemName     String
  amount       String
  priceUsd     Int      // cents

  // payout
  payoutChain  String   // "solana" | "ethereum"
  payoutAddr   String

  contact      String?
  notes        String?

  status       String   @default("submitted") // submitted|accepted|rejected|paid
  adminNote    String?
  txHash       String?
}
